# ARIMA Modeling in R
#time series data
x <- c(10,12,14,13,15,18,20,22,21,24)

# convert into time series
t <- ts(x)

# fit ARIMA model
model <- arima(t, order=c(1,1,1))#Auto Regression,difference,moving avg

# show model
print(model)
plot(t)

# forecast next 3 values
predict(model, n.ahead=3) 

#se: standard error 
